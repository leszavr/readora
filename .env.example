# Окружение приложения
NODE_ENV=development

# Сервер API
PORT=8080
APP_ORIGIN=http://localhost:3000

# База данных PostgreSQL
# Локально проще всего: docker compose up -d postgres
DATABASE_URL=postgresql://readora:readora@localhost:5432/readora

# Сессии (express-session, cookie-based)
# Сгенерируйте: openssl rand -hex 32
SESSION_SECRET=change-me-in-production

# Каталог для загружаемых книг (относительно корня репо или абсолютный путь)
UPLOADS_DIR=./uploads

# Логирование (pino): trace | debug | info | warn | error
LOG_LEVEL=info

# Базовый путь фронтенда (для деплоя за reverse proxy в подпапке)
BASE_PATH=/

# SMTP-настройки (email-верификация, сброс пароля) задаются через админ-панель,
# а не через переменные окружения.
